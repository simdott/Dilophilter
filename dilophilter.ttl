@prefix lv2:  <http://lv2plug.in/ns/lv2core#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix atom: <http://lv2plug.in/ns/ext/atom#> .
@prefix ui:   <http://lv2plug.in/ns/extensions/ui#> .
@prefix doap: <http://usefulinc.com/ns/doap#> .
@prefix units: <http://lv2plug.in/ns/extensions/units#> .
@prefix pprops: <http://lv2plug.in/ns/ext/port-props#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

<urn:simdott:simondelaruotte>
    a foaf:Person ;
    foaf:name "Simon Delaruotte" ;
    foaf:homepage <https://github.com/simdott/dilophilter> .

<urn:simdott:dilophilter>
    a lv2:Plugin ;
    lv2:binary <dilophilter.so> ;
    doap:name "Dilophilter" ;
    doap:maintainer <urn:simdott:simondelaruotte> ;
    doap:license <http://spdx.org/licenses/GPL-2.0-or-later> ;  
    doap:description "Dual filter plugin with independent high-pass and low-pass filters." ;
    rdfs:label "Dilophilter" ;
    rdfs:comment "Dilophilter v1.1.0" ;
    lv2:port [
        a lv2:AudioPort, lv2:InputPort ;
        lv2:index 0 ;
        lv2:symbol "input_left" ;
        lv2:name "Input Left" ;
        rdfs:comment "Left channel audio input" ;
    ], [
        a lv2:AudioPort, lv2:InputPort ;
        lv2:index 1 ;
        lv2:symbol "input_right" ;
        lv2:name "Input Right" ;
        rdfs:comment "Right channel audio input." ;
    ], [
        a lv2:AudioPort, lv2:OutputPort ;
        lv2:index 2 ;
        lv2:symbol "output_left" ;
        lv2:name "Output Left" ;
        rdfs:comment "Left channel audio output." ;
    ], [
        a lv2:AudioPort, lv2:OutputPort ;
        lv2:index 3 ;
        lv2:symbol "output_right" ;
        lv2:name "Output Right" ;
        rdfs:comment "Right channel audio output." ;
    ], [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index 4 ;
        lv2:symbol "hp_slope" ;
        lv2:name "HPF Slope" ;
        lv2:default 7.0 ;
        lv2:minimum 0.0 ;
        lv2:maximum 7.0 ;
        lv2:portProperty lv2:integer ;
        rdfs:comment "High-pass filter slope in dB/octave." ;
        lv2:scalePoint [ rdfs:label "Off" ; rdf:value 7.0 ] ;
        lv2:scalePoint [ rdfs:label "Classic -12dB/oct." ; rdf:value 0.0 ] ;
        lv2:scalePoint [ rdfs:label "Classic -24dB/oct." ; rdf:value 1.0 ] ;
        lv2:scalePoint [ rdfs:label "Classic -48dB/oct." ; rdf:value 2.0 ] ;
        lv2:scalePoint [ rdfs:label "Butterworth -24dB" ; rdf:value 3.0 ] ;
        lv2:scalePoint [ rdfs:label "Butterworth -48dB" ; rdf:value 4.0 ] ;
        lv2:scalePoint [ rdfs:label "Linkwitz-Riley -48dB" ; rdf:value 5.0 ] ;
        lv2:scalePoint [ rdfs:label "Linkwitz-Riley -96dB" ; rdf:value 6.0 ] ;
    ], [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index 5 ;
        lv2:symbol "hp_cutoff" ;
        lv2:name "HP Cutoff" ;
        lv2:default 30.0 ;
        lv2:minimum 20.0 ;
        lv2:maximum 20000.0 ;
        lv2:portProperty pprops:logarithmic ;
        units:unit units:hz ;
        rdfs:comment "High-pass filter cutoff frequency." ;
    ], [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index 6 ;
        lv2:symbol "hp_resonance" ;
        lv2:name "HPF Q" ;
        lv2:default 0.7071 ;
        lv2:minimum 0.1 ;
        lv2:maximum 5.0 ;
        lv2:portProperty pprops:logarithmic ;
        rdfs:comment "High-pass filter resonance adjustment (Classic filters only)" ;
    ], [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index 7 ;
        lv2:symbol "lp_slope" ;
        lv2:name "LPF Slope" ;
        lv2:default 7.0 ;
        lv2:minimum 0.0 ;
        lv2:maximum 7.0 ;
        lv2:portProperty lv2:integer ;
        rdfs:comment "Low-pass filter slope in dB/octave." ;
        lv2:scalePoint [ rdfs:label "Off" ; rdf:value 7.0 ] ;
        lv2:scalePoint [ rdfs:label "Classic -12dB/oct." ; rdf:value 0.0 ] ;
        lv2:scalePoint [ rdfs:label "Classic -24dB/oct." ; rdf:value 1.0 ] ;
        lv2:scalePoint [ rdfs:label "Classic -48dB/oct." ; rdf:value 2.0 ] ;
        lv2:scalePoint [ rdfs:label "Butterworth -24dB" ; rdf:value 3.0 ] ;
        lv2:scalePoint [ rdfs:label "Butterworth -48dB" ; rdf:value 4.0 ] ; 
        lv2:scalePoint [ rdfs:label "Linkwitz-Riley -48dB" ; rdf:value 5.0 ] ;
        lv2:scalePoint [ rdfs:label "Linkwitz-Riley -96dB" ; rdf:value 6.0 ] ;
    ], [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index 8 ;
        lv2:symbol "lp_cutoff" ;
        lv2:name "LP Cutoff" ;
        lv2:default 10000.0 ;
        lv2:minimum 20.0 ;
        lv2:maximum 20000.0 ;
        lv2:portProperty pprops:logarithmic ;
        units:unit units:hz ;
        rdfs:comment "Low-pass filter cutoff frequency." ;
    ], [
        a lv2:ControlPort, lv2:InputPort ;
        lv2:index 9 ;
        lv2:symbol "lp_resonance" ;
        lv2:name "LPF Q" ;
        lv2:default 0.7071 ;
        lv2:minimum 0.1 ;
        lv2:maximum 5.0 ;
        lv2:portProperty pprops:logarithmic ;
        rdfs:comment "Low-pass filter resonance adjustment (Classic filters only)." ;
    ] .
